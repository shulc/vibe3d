{
  "name": "slice",
  "description": "Slice tool (mesh.sliceTool, task 0266 S0) topology: cube (8v/6f) cut by the plane through the drawn Start->End line PERPENDICULAR to the work plane (headless work-plane normal = default world XZ, +Y). A mid-plane cut yields 12v/10f (all-quad): one index-shared crossing vertex per straddled edge + a chord-split of each crossed face. Analytic self-golden (Mesh.cutByPlane is connectivity-correct by construction, task 0108).",
  "source": "Analytic. Cube +/-0.5; plane law = math.planeFromLineAndWorkplane(start, end, +Y). Case midX: line along Z -> plane normal ||X through origin (X=0). Case midZ: line along X -> plane normal ||Z through origin (Z=0). New verts are edge midpoints (t=0.5).",
  "tolerance": 0.0001,
  "cases": [
    {
      "name": "midX",
      "input": [ { "reset": true } ],
      "op": [ { "slice": { "start": [0, 0, -1], "end": [0, 0, 1] } } ],
      "expected_before": { "verts": 8, "faces": 6 },
      "expected_after":  { "verts": 12, "faces": 10 },
      "expected_vertices": [
        [-0.5, -0.5, -0.5], [0.5, -0.5, -0.5], [0.5, 0.5, -0.5], [-0.5, 0.5, -0.5],
        [-0.5, -0.5, 0.5], [0.5, -0.5, 0.5], [0.5, 0.5, 0.5], [-0.5, 0.5, 0.5],
        [0, -0.5, -0.5], [0, 0.5, -0.5], [0, -0.5, 0.5], [0, 0.5, 0.5]
      ],
      "lerp_checks": [
        { "a": [-0.5, -0.5, -0.5], "b": [0.5, -0.5, -0.5], "t": 0.5, "point": [0, -0.5, -0.5] },
        { "a": [-0.5, 0.5, -0.5], "b": [0.5, 0.5, -0.5], "t": 0.5, "point": [0, 0.5, -0.5] },
        { "a": [-0.5, -0.5, 0.5], "b": [0.5, -0.5, 0.5], "t": 0.5, "point": [0, -0.5, 0.5] },
        { "a": [-0.5, 0.5, 0.5], "b": [0.5, 0.5, 0.5], "t": 0.5, "point": [0, 0.5, 0.5] }
      ]
    },
    {
      "name": "midZ",
      "input": [ { "reset": true } ],
      "op": [ { "slice": { "start": [-1, 0, 0], "end": [1, 0, 0] } } ],
      "expected_before": { "verts": 8, "faces": 6 },
      "expected_after":  { "verts": 12, "faces": 10 },
      "expected_vertices": [
        [-0.5, -0.5, -0.5], [0.5, -0.5, -0.5], [0.5, 0.5, -0.5], [-0.5, 0.5, -0.5],
        [-0.5, -0.5, 0.5], [0.5, -0.5, 0.5], [0.5, 0.5, 0.5], [-0.5, 0.5, 0.5],
        [-0.5, -0.5, 0], [0.5, -0.5, 0], [-0.5, 0.5, 0], [0.5, 0.5, 0]
      ],
      "lerp_checks": [
        { "a": [-0.5, -0.5, -0.5], "b": [-0.5, -0.5, 0.5], "t": 0.5, "point": [-0.5, -0.5, 0] },
        { "a": [0.5, -0.5, -0.5], "b": [0.5, -0.5, 0.5], "t": 0.5, "point": [0.5, -0.5, 0] },
        { "a": [-0.5, 0.5, -0.5], "b": [-0.5, 0.5, 0.5], "t": 0.5, "point": [-0.5, 0.5, 0] },
        { "a": [0.5, 0.5, -0.5], "b": [0.5, 0.5, 0.5], "t": 0.5, "point": [0.5, 0.5, 0] }

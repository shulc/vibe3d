# Local QA tooling (reference comparison against external engines) —
# kept on disk for local parity checks, not published. No trailing slash so
# the rule also matches a symlink at this path (symlinks to a private repo).
/tools/local
# Local dev guidance for Claude Code — kept on disk, not published.
CLAUDE.md
# Internal design / planning docs — kept on disk, not published.
# No trailing slash so the rule also matches a symlink at this path.
/doc
# RPR runtime kernel cache + logs (created next to vibe3d.exe at runtime)
cache/
tahoenext.log
# Release artifacts
vibe3d-*.zip
vibe3d-windows-render/
vibe3d-linux-render/
vibe3d-macos-render/
# Self-contained Linux AppImage + its build cache (downloaded packaging tools,
# staged AppDir) — produced by tools/release/bundle_linux_appimage.sh.
*.AppImage
/tools/release/.appimage-build/

# Per-test wall-clock timing cache used by run_test.d's LPT scheduler.
# Machine-specific (durations depend on the host), so not published.
.test_timings.json

# perf harness generated output (results.json is a transient per-run dump;
# baseline.json is committed as the reference — see tools/perf/README.md)
tools/perf/results.json

# `frames` subcommand (task 0195) generated output — mirrors results.json
# above; frames_baseline.json is the committed reference (mirrors
# baseline.json), frames_results.json is the transient per-run dump.
tools/perf/frames_results.json

# Per-host run history (task 0197 — perf tooling consolidation): one JSONL
# per host, appended to by every `ops`/`frames` run. Machine-specific (like
# .test_timings.json above), read by `--trend`.
tools/perf/history/

# `flame` subcommand generated output (task 0197) — perf.data/perf.txt/
# folded stacks, mirrors the retired tools/perf_subpatch/out/.
tools/perf/flame/out/

# dyaml 0.10.0 unittests (compiled into -unittest test binaries via
# test_forms_loader) write a scratch example.yaml into cwd (loader.d:248)
/example.yaml

# graphify knowledge-graph build output (generated by `graphify update`)
graphify-out/
toolcards/
